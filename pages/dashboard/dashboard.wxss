.dashboard-banner {
  min-height: 150rpx;
}

.stats-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 18rpx;
  margin-top: 26rpx;
}

.stat-card {
  min-height: 150rpx;
  padding: 24rpx;
  border-radius: 26rpx;
  background: #fff;
  border: 1rpx solid #ffe1e7;
  box-shadow: 0 10rpx 28rpx rgba(148, 36, 56, 0.07);
}

.stat-card.highlight {
  color: #fff;
  background: linear-gradient(135deg, #ff0036, #ff5a00);
}

.stat-card.warning {
  background: linear-gradient(135deg, #fff5f0, #fff);
}

.stat-label {
  font-size: 24rpx;
  color: inherit;
  opacity: 0.75;
}

.stat-value {
  margin-top: 18rpx;
  font-size: 36rpx;
  font-weight: 900;
  color: inherit;
}

.flow-row {
  display: flex;
  gap: 18rpx;
}

.flow-row.mini {
  margin-top: 20rpx;
}

.flow-card {
  flex: 1;
  padding: 24rpx;
  border-radius: 24rpx;
  text-align: center;
  background: #fff7f8;
}

.flow-card.in {
  border: 1rpx solid #ffd6a3;
}

.flow-card.out {
  border: 1rpx solid #ffc3d0;
}

.flow-name {
  font-size: 24rpx;
  color: #666;
}

.flow-num {
  margin-top: 12rpx;
  font-size: 40rpx;
  font-weight: 900;
  color: #ff0036;
}

.flow-money {
  margin-top: 8rpx;
  color: #222;
  font-size: 26rpx;
  font-weight: 700;
}

.month-summary {
  display: flex;
  justify-content: space-around;
  padding: 28rpx;
  border-radius: 24rpx;
  background: linear-gradient(135deg, #fff0f3, #fff8f2);
  text-align: center;
}

.month-label {
  font-size: 24rpx;
  color: #777;
}

.month-value {
  margin-top: 12rpx;
  font-size: 34rpx;
  color: #ff0036;
  font-weight: 900;
}
